APP_NAME=Job Application Hub API
APP_ENV=development
API_V1_PREFIX=/api/v1
DATABASE_URL=sqlite:///./job_application_hub.db
# Example Postgres URL:
# DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/job_application_hub
# If using Supabase Postgres directly from FastAPI, set either DATABASE_URL or SUPABASE_DB_URL:
# SUPABASE_DB_URL=postgresql+psycopg://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres
BRAVE_SEARCH_API_KEY=
OPENREUTER_API=
OPENROUTER_MODEL=google/gemini-2.5-flash
GOOGLE_SHEETS_CREDENTIALS_JSON=
GOOGLE_SHEETS_SPREADSHEET_ID=
ALLOWED_ORIGINS=http://localhost:3000
